{
  "name": "globalchain-selenium-tests",
  "version": "1.0.0",
  "description": "Selenium WebDriver E2E tests for GlobalChain Web Dashboard",
  "main": "index.js",
  "scripts": {
    "test": "mocha tests/**/*.test.js --timeout 30000 --reporter spec",
    "test:login": "mocha tests/login.test.js --timeout 30000 --reporter spec",
    "test:headless": "TEST_HEADLESS=true mocha tests/**/*.test.js --timeout 30000 --reporter spec"
  },
  "dependencies": {
    "selenium-webdriver": "^4.20.0"
  },
  "devDependencies": {
    "chromedriver": "^149.0.2",
    "dotenv": "^16.4.5",
    "mocha": "^10.4.0"
  },
  "author": "GlobalChain Team",
  "license": "MIT"
}
