{
  "name": "globalchain-selenium-tests",
  "version": "1.0.0",
  "description": "Selenium WebDriver E2E tests for GlobalChain Web Dashboard",
  "main": "index.js",
  "scripts": {
    "test": "cross-env mocha tests/**/*.test.js --timeout 60000 --reporter spec --exit",
    "test:login": "cross-env mocha tests/login.test.js --timeout 60000 --reporter spec --exit",
    "test:login:headless": "cross-env TEST_HEADLESS=true mocha tests/login.test.js --timeout 60000 --reporter spec --exit",
    "test:smoke:headless": "cross-env TEST_HEADLESS=true mocha tests/smoke.test.js --timeout 600000 --reporter spec --exit",
    "test:headless": "cross-env TEST_HEADLESS=true mocha tests/**/*.test.js --timeout 60000 --reporter spec --exit"
  },
  "dependencies": {
    "selenium-webdriver": "^4.20.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "mocha": "^10.4.0"
  },
  "author": "GlobalChain Team",
  "license": "MIT"
}
